# ── Netlify (edge proxy — preferred) ─────────────────────────────
RAILWAY_API_URL=            # Railway backend URL, e.g. https://verifyid-production.up.railway.app

# ── Frontend (optional — only if not using Netlify edge proxy) ─
VITE_API_URL=               # Railway backend URL baked into the frontend build

# ── Backend CORS ───────────────────────────────────────────────
FRONTEND_URL=               # Netlify site URL, e.g. https://dsc-infoverifyid.com

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (Railway provides this automatically)

# ── Email (Railway backend — required for submission emails) ─
RESEND_API_KEY=           # Your Resend API key (starts with re_)
RESEND_FROM_EMAIL=        # e.g. VerifyID <noreply@dsc-infoverifyid.com> after domain is verified in Resend
RESEND_REPLY_TO=          # Real monitored inbox for replies (improves deliverability), e.g. support@dsc-infoverifyid.com
ADMIN_NOTIFICATION_EMAIL= # Server-side inbox for new submission alerts (default: rextest84@gmail.com; never shown on site)

# ── Auth / Security ────────────────────────────────────────────
APP_SECRET=               # Any random string (used for JWT signing)
ADMIN_COMPOSE_PASSWORD=   # Password to unlock /compose email tool (Railway only)
ADMIN_COMPOSE_SECRET=     # Optional; JWT signing for admin cookie (defaults to APP_SECRET)

# ── OAuth (optional — only if you add login later) ───────────
APP_ID=
VITE_KIMI_AUTH_URL=
VITE_APP_ID=
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=
